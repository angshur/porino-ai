---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
  <div class="page">
    <div class="page-header">
      <div class="page-header-inner">
        <div class="breadcrumb"><a href="/blog">Blog</a></div>
        <h1 class="page-title">{post.data.title}</h1>
        <div class="post-meta">
          <span class="meta-author">{post.data.author}</span>
          <span class="meta-sep">·</span>
          <span class="meta-date">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          {post.data.readTime && (
            <>
              <span class="meta-sep">·</span>
              <span class="meta-read-time">{post.data.readTime} read</span>
            </>
          )}
        </div>
      </div>
    </div>

    <div class="page-body">
      <div class="page-body-inner">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page {
    min-height: 80vh;
  }

  .page-header {
    border-bottom: 1px solid var(--color-border);
    padding: 56px 24px 36px;
  }

  .page-header-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin-bottom: 20px;
  }

  .breadcrumb a {
    color: var(--color-text-tertiary);
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--color-text-secondary);
  }

  .page-title {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    line-height: 1.35;
    margin: 0 0 20px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .meta-author {
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .meta-sep {
    font-size: 13px;
    color: var(--color-text-tertiary);
  }

  .meta-date {
    font-size: 13px;
    color: var(--color-text-tertiary);
  }

  .meta-read-time {
    font-size: 13px;
    color: var(--color-text-tertiary);
  }

  .page-body {
    padding: 48px 24px 100px;
  }

  .page-body-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .prose :global(h2) {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 40px 0 14px;
    line-height: 1.4;
  }

  .prose :global(h3) {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 28px 0 10px;
  }

  .prose :global(p) {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 18px;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .prose :global(em) {
    color: var(--color-text-primary);
    font-style: italic;
  }

  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 18px;
    padding-left: 20px;
  }

  .prose :global(li) {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 6px;
  }

  .prose :global(li strong) {
    color: var(--color-text-primary);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 24px;
    font-size: 13px;
  }

  .prose :global(th) {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .prose :global(td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    line-height: 1.5;
    vertical-align: top;
  }

  .prose :global(td strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .prose :global(pre) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 20px;
    overflow-x: auto;
    margin: 0 0 24px;
  }

  .prose :global(code) {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .prose :global(p code) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 13px;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    margin: 0 0 18px;
    padding: 4px 0 4px 20px;
  }

  .prose :global(blockquote p) {
    color: var(--color-text-tertiary);
    font-style: italic;
    margin: 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }
</style>
