---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog" description="Writing on agentic AI infrastructure, context design, and building reliable systems.">
  <div class="page">
    <div class="page-header">
      <div class="page-header-inner">
        <div class="breadcrumb">Porino</div>
        <h1 class="page-title">Blog</h1>
        <p class="page-desc">
          Writing on agentic AI infrastructure, context design, and building reliable systems.
          For practitioners and operators — people who build, not people who demo.
        </p>
        <div class="page-meta">{posts.length} articles</div>
      </div>
    </div>

    <div class="page-body">
      <div class="page-body-inner">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-row">
            <div class="post-meta">
              <span class="post-date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              {post.data.readTime && <span class="post-read-time">{post.data.readTime}</span>}
            </div>
            <div class="post-content">
              <div class="post-title">{post.data.title}</div>
              <div class="post-desc">{post.data.description}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .page {
    min-height: 80vh;
  }

  .page-header {
    border-bottom: 1px solid var(--color-border);
    padding: 56px 24px 40px;
  }

  .page-header-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin-bottom: 16px;
  }

  .page-title {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 12px;
  }

  .page-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 16px;
    max-width: 560px;
  }

  .page-meta {
    font-size: 12px;
    color: var(--color-text-tertiary);
  }

  .page-body {
    padding: 8px 24px 80px;
  }

  .page-body-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .post-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.15s;
    border-radius: 4px;
  }

  .post-row:first-child {
    border-top: 1px solid var(--color-border);
    margin-top: 24px;
  }

  .post-row:hover .post-title {
    color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 2px;
  }

  .post-date {
    font-size: 12px;
    color: var(--color-text-tertiary);
  }

  .post-read-time {
    font-size: 12px;
    color: var(--color-text-tertiary);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .post-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.4;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 640px;
  }
</style>
