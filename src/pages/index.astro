---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    name: 'Agentic Systems',
    slug: 'agentic-systems',
    count: 22,
    description: 'Orchestration patterns, context isolation, model routing, evals, and governance for multi-agent systems.',
  },
  {
    name: 'Stream Processing',
    slug: 'stream-processing',
    count: 2,
    description: 'The primitives behind Kafka, Flink, and real-time data pipelines.',
  },
  {
    name: 'Storage & Table Formats',
    slug: 'storage-table-formats',
    count: 2,
    description: 'Iceberg, Delta Lake, Hudi — why table formats exist and when they matter.',
  },
  {
    name: 'Orchestration',
    slug: 'orchestration',
    count: 2,
    description: 'From cron jobs to DAGs to asset-centric pipelines.',
  },
  {
    name: 'ML Infrastructure',
    slug: 'ml-infrastructure',
    count: 2,
    description: 'Feature stores, training-serving skew, and the infrastructure behind production ML.',
  },
  {
    name: 'Real-Time & OLAP',
    slug: 'real-time-olap',
    count: 2,
    description: 'ClickHouse, Pinot, and the architecture of sub-second analytics.',
  },
  {
    name: 'Observability & Quality',
    slug: 'observability-quality',
    count: 2,
    description: 'Data health, lineage, and the five pillars of observable data systems.',
  },
  {
    name: 'Platform Deep Dives',
    slug: 'platform-deep-dives',
    count: 16,
    description: 'AWS, GCP, Azure, Snowflake, Databricks — honest comparisons and cost traps.',
  },
];
---

<Layout title="Porino" description="Infrastructure patterns and specialists for teams building multi-agent AI systems that actually work in production.">
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-provocation">
        Teams are rushing into multi-agent systems. The demos work.<br />
        The production systems don't. The bottleneck is almost never the agent.
      </p>
      <h1 class="hero-headline">
        The infrastructure layer<br />is what makes agents reliable.
      </h1>
      <p class="hero-sub">
        Fan-out and fan-in. Idempotent tasks. Context isolation. Model routing.
        Trace IDs across agent chains. Data governance. These are data engineering
        primitives — and they're what separates a working agent system from a stalled pilot.
      </p>
      <div class="hero-actions">
        <a href="/patterns/agentic-systems/foundations/data-layer-prerequisite-ai-agents" class="btn-primary">Read the thesis</a>
        <a href="/patterns" class="btn-secondary">Browse patterns</a>
      </div>
    </div>
  </section>

  <section class="thesis-strip">
    <div class="section-inner">
      <div class="strip-grid">
        <div class="strip-item">
          <span class="strip-label">The problem</span>
          <span class="strip-text">LangGraph defaults and bloated shared context cause latency and hallucination — not the model</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
          <span class="strip-label">The insight</span>
          <span class="strip-text">Data engineering primitives — idempotency, fan-in/out, observability — map directly to agent infrastructure</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
          <span class="strip-label">The implication</span>
          <span class="strip-text">The teams shipping reliable agents are the ones who understand what sits underneath</span>
        </div>
      </div>
    </div>
  </section>

  <section class="patterns-section">
    <div class="section-inner">
      <div class="section-header">
        <div>
          <h2 class="section-title">Patterns Library</h2>
          <p class="section-subtitle">Agentic systems first. Data infrastructure underneath. Written for practitioners, not demos.</p>
        </div>
        <a href="/patterns" class="section-link">View all →</a>
      </div>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={`/patterns/${cat.slug}`} class="category-card">
            <div class="category-top">
              <span class="category-name">{cat.name}</span>
              <span class="category-count">{cat.count}</span>
            </div>
            <p class="category-desc">{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="who-section">
    <div class="section-inner">
      <div class="who-box">
        <span class="who-label">Behind this</span>
        <h2 class="who-name">Angshuman Rudra</h2>
        <p class="who-bio">
          Twenty years across data engineering, AI infrastructure, and platform architecture — including founding-era work at Yahoo and building the data backbone at TapClicks, where the platform processed $10B+ in annual ad spend across 200+ connectors. I've been through enough cloud migrations, warehouse evaluations, and agentic pilots to have strong opinions about what breaks and why. Porino is where I write those opinions down — and work directly with the teams making the decisions that matter.
        </p>
      </div>
    </div>
  </section>

  <section class="session-section">
    <div class="section-inner">
      <div class="session-box">
        <div class="session-content">
          <span class="session-label">Advisory</span>
          <h2 class="session-title">Architecture Clarity Session</h2>
          <p class="session-desc">
            Most infrastructure decisions get made wrong because the person making them hasn't seen enough of them go wrong. Before you sign the Snowflake contract, migrate to GCP, or hire three engineers to build what a different tool already does — spend 90 minutes with someone who has.
          </p>
          <p class="session-desc">
            You get a working session reviewing your current setup and the decision in front of you, followed by a written 1-pager within 24 hours: what we covered, the honest tradeoffs, and what I'd do next.
          </p>
          <p class="session-price">$750 &mdash; fixed. No pitch, no retainer conversation.</p>
          <p class="session-footnote">
            If the session surfaces implementation work, I can connect you with a vetted specialist from the Porino network. That's a separate conversation — only if you need it.
          </p>
        </div>
        <div class="session-form-wrap">
          <form id="clarity-form" class="session-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            <div class="form-field">
              <label for="sess-name" class="form-label">Name</label>
              <input type="text" id="sess-name" name="name" required class="form-input" placeholder="Your name" />
            </div>
            <div class="form-field">
              <label for="sess-email" class="form-label">Email</label>
              <input type="email" id="sess-email" name="email" required class="form-input" placeholder="your@email.com" />
            </div>
            <div class="form-field">
              <label for="sess-question" class="form-label">What are you trying to figure out?</label>
              <textarea id="sess-question" name="question" required class="form-input form-textarea" rows="3" placeholder="Describe the decision or problem you're facing"></textarea>
            </div>
            <button type="submit" class="form-submit">Request a session →</button>
          </form>
          <div id="form-success" class="form-success" style="display: none;">
            <p class="success-title">Request received.</p>
            <p class="success-desc">I'll reply within 1 business day to confirm and schedule.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="newsletter-section">
    <div class="section-inner">
      <div class="newsletter-box">
        <div class="newsletter-text">
          <h3 class="newsletter-title">Written for people who build, not people who demo.</h3>
          <p class="newsletter-desc">New patterns and research when there's something worth saying.</p>
        </div>
        <form class="newsletter-form">
          <input type="email" placeholder="your@email.com" class="newsletter-input" />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 96px 24px 80px;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-provocation {
    font-size: 13px;
    color: var(--color-text-tertiary);
    line-height: 1.7;
    margin: 0 0 28px;
    font-style: italic;
  }

  .hero-headline {
    font-size: 42px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0 0 20px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 36px;
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
  }

  .btn-primary {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-primary);
    background-color: var(--color-accent);
    padding: 8px 16px;
    border-radius: 5px;
    transition: background-color 0.15s;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
  }

  .btn-secondary {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
    background-color: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    padding: 8px 16px;
    border-radius: 5px;
    transition: color 0.15s, border-color 0.15s;
  }

  .btn-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .thesis-strip {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }

  .strip-grid {
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .strip-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px 32px;
  }

  .strip-divider {
    width: 1px;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .strip-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .strip-text {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .section-subtitle {
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin: 4px 0 0;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .entry-card {
    background-color: var(--color-surface);
    padding: 28px;
    transition: background-color 0.15s;
    display: block;
  }

  .entry-card:hover {
    background-color: var(--color-surface-raised);
  }

  .entry-icon {
    font-size: 18px;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .entry-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 6px;
  }

  .entry-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 8px;
  }

  .entry-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .patterns-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .section-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 13px;
    color: var(--color-text-secondary);
    transition: color 0.15s;
  }

  .section-link:hover {
    color: var(--color-text-primary);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .category-card {
    background-color: var(--color-surface);
    padding: 20px;
    display: block;
    transition: background-color 0.15s;
  }

  .category-card:hover {
    background-color: var(--color-surface-raised);
  }

  .category-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .category-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .category-count {
    font-size: 11px;
    color: var(--color-text-tertiary);
    background-color: var(--color-surface-raised);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .category-desc {
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .newsletter-section {
    padding: 64px 0;
  }

  .newsletter-box {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background-color: var(--color-surface);
    padding: 36px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .newsletter-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }

  .newsletter-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .newsletter-input {
    font-size: 13px;
    font-family: inherit;
    color: var(--color-text-primary);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 8px 14px;
    width: 220px;
    outline: none;
    transition: border-color 0.15s;
  }

  .newsletter-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .newsletter-input:focus {
    border-color: var(--color-accent);
  }

  .newsletter-btn {
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    color: var(--color-text-primary);
    background-color: var(--color-accent);
    border: none;
    border-radius: 5px;
    padding: 8px 16px;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .newsletter-btn:hover {
    background-color: var(--color-accent-hover);
  }

  /* Who section */
  .who-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .who-box {
    max-width: 640px;
  }

  .who-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 12px;
  }

  .who-name {
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 16px;
  }

  .who-bio {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
  }

  /* Session section */
  .session-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .session-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .session-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 12px;
  }

  .session-title {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .session-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 16px;
  }

  .session-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 24px 0 12px;
  }

  .session-footnote {
    font-size: 12px;
    color: var(--color-text-tertiary);
    line-height: 1.6;
    margin: 0;
  }

  .session-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .form-input {
    font-size: 13px;
    font-family: inherit;
    color: var(--color-text-primary);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .form-input:focus {
    border-color: var(--color-accent);
  }

  .form-textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-submit {
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    color: var(--color-text-primary);
    background-color: var(--color-accent);
    border: none;
    border-radius: 5px;
    padding: 10px 20px;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .form-submit:hover {
    background-color: var(--color-accent-hover);
  }

  .form-success {
    padding: 24px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background-color: var(--color-surface);
  }

  .success-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 6px;
  }

  .success-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 768px) {
    .session-box {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<script>
  const form = document.getElementById('clarity-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form!);
    const response = await fetch(form!.action, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' },
    });
    if (response.ok) {
      form!.style.display = 'none';
      if (success) success.style.display = 'block';
    }
  });
</script>
